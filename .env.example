NODE_ENV=development
APP_ENV=local
HOST=0.0.0.0
PORT=3000

DATABASE_URL=postgresql://postgres@127.0.0.1:55432/typetalk_dev?schema=public

JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30
APP_ENCRYPTION_KEY=replace_me_app_key
IP_HASH_KEY_V1=replace_me_ip_hash_key

GOOGLE_CLIENT_ID=replace_me
GOOGLE_WEB_CLIENT_ID=replace_me
WEB_AUTH_REFRESH_COOKIE_NAME=typetalk_refresh

PADDLE_API_KEY=replace_me
PADDLE_WEBHOOK_SECRET=replace_me
PADDLE_PRICE_ID_PRO_MONTHLY=replace_me
PADDLE_PRICE_ID_PRO_YEARLY=replace_me
PADDLE_ENV=sandbox
BILLING_CHECKOUT_ENABLED=false
BILLING_CUSTOMER_PORTAL_ENABLED=false

STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_PRICE_ID_PRO_MONTHLY=replace_me
STRIPE_PRICE_ID_PRO_YEARLY=replace_me
BILLING_WEBHOOK_RETRY_BATCH_SIZE=25
BILLING_WEBHOOK_RETRY_BASE_DELAY_SECONDS=60
BILLING_WEBHOOK_RETRY_MAX_DELAY_SECONDS=3600
BILLING_WEBHOOK_STALE_LOCK_TIMEOUT_SECONDS=300

PLAY_PACKAGE_NAME=replace_me
PLAY_SERVICE_ACCOUNT_JSON=replace_me
PLAY_PUBSUB_AUDIENCE=replace_me
PLAY_PUBSUB_SERVICE_ACCOUNT=replace_me

EMAIL_PROVIDER_MODE=resend
EMAIL_PROVIDER_API_KEY=replace_me
EMAIL_FROM=no-reply@typetalk.app

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_REQUEST_CODE_MAX_PER_IP=5
AUTH_VERIFY_CODE_MAX_PER_IP=10
ADMIN_ALLOWLIST_EMAILS=admin@example.com
RAW_IP_RETENTION_HOURS=24
SECURITY_RETENTION_BATCH_SIZE=500
ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_DSN=
MAX_ACTIVE_DEVICES_PER_USER=10
ALLOWED_ORIGINS=https://typetalk.app,https://www.typetalk.app
MAX_JSON_BODY_BYTES=1048576
MAX_WEBHOOK_BODY_BYTES=524288
